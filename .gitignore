# --- Folders and Blobs ---
# Ignore compiled binaries and object files
*.o
*.so
*.bin
*.exe

# --- Editor & IDE State ---
# Neovim / NvChad / LazyVim state (Keep your lua configs, ignore the data)
nvim/undo/
nvim/view/
nvim/shada/
NvChad/undo/
NvChad/view/

# --- System & Tool State ---
# Ignore dconf database (binary file, better to manage via scripts)
dconf/

# Language server/tooling cache
node_modules/
.venv/
__pycache__/
target/ # Rust builds
.direnv/
.mise/
go/
ibus/
ibus/bus/
obs-studio/

# --- Shell & Terminal History ---
# Don't track your private command history
nushell/history.txt
tmux/resurrect/
zsh/.zsh_history
bash/.bash_history

# --- App Specific Blobs ---
# Browsers and heavy apps store massive caches here
chromium/
brave/
obsidian/.obsidian/workspace.json
obsidian/.obsidian/cache/
Typora/
Pinta/
xournalpp/cache/

# --- Fonts & Assets ---
# Usually better to install these via package manager
*.ttf
*.otf
*.woff
*.woff2

# --- Backups & Temps ---
# Ignore the .bak files like your starship.toml.bak
*.bak
*~
*.swp
*.tmp
*.log

# --- Secrets ---
# Never track API keys or private tokens
.env
credentials
*.pem
*.key
